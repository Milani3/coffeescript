{
  "name": "coffeescript",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install",
    "build": "npm run build --workspace=frontend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "dotnet run",
    "dev": "concurrently \"npm run dev:frontend\" \"dotnet run\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
